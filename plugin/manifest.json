{
  "manifest_version": 3,
  "name": "All2MD Current Page",
  "version": "0.1.0",
  "description": "Extract the current article page into Markdown and download it directly from Chrome.",
  "permissions": [
    "activeTab",
    "tabs",
    "downloads",
    "scripting"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://*.twimg.com/*",
    "https://github.com/*",
    "https://raw.githubusercontent.com/*",
    "https://*.githubusercontent.com/*",
    "https://mp.weixin.qq.com/*",
    "https://mmbiz.qpic.cn/*",
    "https://*.qpic.cn/*",
    "https://www.zhihu.com/*",
    "https://zhuanlan.zhihu.com/*",
    "https://*.zhimg.com/*",
    "https://www.toutiao.com/*",
    "https://m.toutiao.com/*",
    "https://*.toutiaoimg.com/*",
    "https://*.byteimg.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "All2MD",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://github.com/*",
        "https://mp.weixin.qq.com/*",
        "https://www.zhihu.com/*",
        "https://zhuanlan.zhihu.com/*",
        "https://www.toutiao.com/*",
        "https://m.toutiao.com/*"
      ],
      "js": [
        "lib/platform.js",
        "lib/markdown.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
